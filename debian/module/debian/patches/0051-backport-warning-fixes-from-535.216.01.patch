                                          struct NvKmsKapiDevice *device,
                                          int *status)
 {
@@ -856,6 +856,7 @@ void NVKMS_API_CALL nvkms_close_common(struct nvkms_per_open *popen)
     nvkms_free(popen, sizeof(*popen));
